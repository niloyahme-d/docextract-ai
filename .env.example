# ---- LLM Providers (only fill in the one(s) you plan to use) ----
# The AI extraction path is provider-agnostic - set PROVIDER to whichever
# key you populate below.

# Which provider to use for AI-based extraction: openai | anthropic | gemini
AI_PROVIDER=anthropic

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Google Sheets output (optional) ----
# Path to a Google service-account JSON key. Leave blank to disable Sheets output.
GOOGLE_SERVICE_ACCOUNT_FILE=

# ---- OCR ----
# Path to the tesseract binary if it's not on PATH (e.g. on Windows)
TESSERACT_CMD=

# ---- Misc ----
LOG_LEVEL=INFO
